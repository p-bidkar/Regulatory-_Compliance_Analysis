# ===========================================
# Compliance AI System - Environment Configuration
# ===========================================

# -------------------------------------------
# LLM Provider Selection
# Options: "anthropic", "nvidia", "openai"
# -------------------------------------------
LLM_PROVIDER=anthropic

# -------------------------------------------
# API Keys (set based on your chosen provider)
# -------------------------------------------
# Anthropic API (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NVIDIA API (for NVIDIA-hosted models like Llama 3.1, Mistral, etc.)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenAI API (fallback/alternative)
OPENAI_API_KEY=your_openai_api_key_here

# -------------------------------------------
# Model Configuration (provider-specific defaults)
# -------------------------------------------
# For NVIDIA: meta/llama-3.1-405b-instruct, meta/llama-3.1-70b-instruct, mistralai/mistral-large-2-instruct
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# For OpenAI: gpt-4o, gpt-4-turbo-preview
MODEL_NAME=claude-3-5-sonnet-20241022

# Embedding Model
# For NVIDIA: nvidia/nv-embedqa-e5-v5, nvidia/nv-embedqa-mistral-7b-v2
# For OpenAI/Anthropic (via OpenAI embedding API): text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-large

# NVIDIA Base URL (only used if LLM_PROVIDER=nvidia)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# -------------------------------------------
# Retrieval Settings
# -------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# Vector DB (in-memory for MVP)
VECTOR_DB_PATH=./data/vector_db

# -------------------------------------------
# Mock Mode (set to "true" if no API key available)
# -------------------------------------------
MOCK_MODE=false

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=INFO

# -------------------------------------------
# Retry Configuration
# -------------------------------------------
MAX_RETRIES=3
RETRY_DELAY=1.0
