# Anthropic API Key
ANTHROPIC_API_KEY=your_api_key_here

# Model Configuration
MODEL_NAME=claude-3-5-sonnet-20241022
EMBEDDING_MODEL=text-embedding-3-large

# Retrieval Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5

# Vector DB (in-memory for MVP)
VECTOR_DB_PATH=./data/vector_db

# Mock Mode (set to "true" if no API key available)
MOCK_MODE=false
